# Constrails example environment configuration
# Copy to .env and adjust values for your environment.

# API
API_HOST=0.0.0.0
API_PORT=8000
API_ROOT_PATH=
DEBUG=false

# Database
DATABASE_URL=sqlite:///./constrail-dev.db
DATABASE_POOL_SIZE=5
DATABASE_ECHO=false

# Redis (optional)
REDIS_URL=

# Security
SECRET_KEY=change-me-in-production
TOKEN_ALGORITHM=HS256
TOKEN_EXPIRE_MINUTES=30

# Sandbox
SANDBOX_TYPE=dev
DOCKER_SOCKET=
SANDBOX_TIMEOUT_SECONDS=300
SANDBOX_MEMORY_LIMIT_MB=512
SANDBOX_CPU_SHARES=512

# Policy
POLICY_ENGINE=opa
OPA_URL=http://localhost:8181
OPA_POLICY_PACKAGE=constrail
POLICY_DIR=./policies

# Risk thresholds
RISK_THRESHOLD_MEDIUM=0.3
RISK_THRESHOLD_HIGH=0.7
RISK_THRESHOLD_CRITICAL=0.9

# Audit
AUDIT_LOG_DIR=./audit
AUDIT_SIGN_LOGS=false
AUDIT_SIGNING_KEY=

# Approval
APPROVAL_WEBHOOK_URL=
APPROVAL_AUTO_APPROVE_LOW_RISK=false

# Anomaly detection
ANOMALY_DETECTION_ENABLED=true
ANOMALY_BURST_THRESHOLD=100
ANOMALY_NEW_TOOL_ALERT=true
