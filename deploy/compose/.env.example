# Example compose environment for Constrails
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=sqlite:///./constrail-dev.db
POLICY_ENGINE=opa
OPA_URL=http://opa:8181
OPA_POLICY_PACKAGE=constrail
POLICY_DIR=./policies
SANDBOX_TYPE=docker
DOCKER_SOCKET=unix:///var/run/docker.sock
SANDBOX_TIMEOUT_SECONDS=300
SANDBOX_MEMORY_LIMIT_MB=512
SECRET_KEY=change-me-in-production
